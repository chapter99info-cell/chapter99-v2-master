<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chapter99 Staff"
            android:textColor="#2D5016"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="One-time shop setup"
            android:textColor="#1A1A1A"
            android:textSize="18sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Type your shop code (slug) exactly as Chapter99 uses it — for example mira or princess. You only do this once on this device."
            android:textColor="#6B7280"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Shop code"
            android:textColor="#1A1A1A"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/shopSlugInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#F8F5F0"
            android:hint="mira"
            android:inputType="text"
            android:padding="14dp"
            android:singleLine="true"
            android:textColor="#1A1A1A"
            android:textColorHint="#9CA3AF"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/setupError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#B91C1C"
            android:textSize="14sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/saveShopBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:backgroundTint="#2D5016"
            android:padding="14dp"
            android:text="Save and open staff app"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="To change the shop later: open the app menu (three dots) or clear app data in Android Settings, then reopen Chapter99 Staff."
            android:textColor="#9CA3AF"
            android:textSize="13sp" />
    </LinearLayout>
</ScrollView>
