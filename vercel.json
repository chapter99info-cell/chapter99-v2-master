{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    { "path": "/api/cron/daily-report", "schedule": "0 10 * * *" },
    { "path": "/api/cron/winback", "schedule": "0 9 * * *" },
    { "path": "/api/cron/birthday", "schedule": "0 9 * * *" },
    { "path": "/api/cron/review-sentiment", "schedule": "0 12 * * *" },
    { "path": "/api/cron/alerts", "schedule": "0 8 * * *" },
    { "path": "/api/cron/booking-reminders", "schedule": "0 7 * * *" },
    { "path": "/api/cron/daily-sheets", "schedule": "0 11 * * *" }
  ]
}
