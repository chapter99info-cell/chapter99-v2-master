{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }],
  "crons": [
    {
      "path": "/api/cron/daily-sheets",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/alerts",
      "schedule": "0 22 * * *"
    }
  ]
}
