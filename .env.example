VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_SHOP_ID=shop-001

# Custom domains → shop slugs (hostname only, no protocol)
# Vercel: SHOP_DOMAIN_MAP — edge middleware injects ?shop=
# Client build: VITE_SHOP_DOMAIN_MAP — same JSON for host resolution without redirect
SHOP_DOMAIN_MAP={"mira-thai-massage.com.au":"mira","sdcws.com.au":"sdcws"}
VITE_SHOP_DOMAIN_MAP={"mira-thai-massage.com.au":"mira","sdcws.com.au":"sdcws"}

SUPABASE_SERVICE_ROLE_KEY=eyJ...
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
RESEND_API_KEY=
CRON_SECRET=

# Stripe (server only — set in Vercel, never VITE_ prefix)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google Sheets (Vercel server only — share spreadsheet with this email)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
