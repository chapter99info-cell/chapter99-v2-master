# Trip2Talk V4 (trip2talk-v4 Vercel project — production)
VITE_APP_URL=https://trip2talk.com.au
VITE_PUBLIC_APP_URL=https://trip2talk.com.au
VITE_TRIP2TALK_URL=https://trip2talk.com.au
VITE_APP_PRODUCT=trip2talk

# Chapter99 / Mira Thai (chapter99-v4-complete project only)
# VITE_CHAPTER99_URL=https://www.chapter99info.tech

# Shop custom domains — primary map is shops.config.json (committed).
# These env vars only OVERRIDE entries in that file (optional):
# SHOP_DOMAIN_MAP={"mirathaimassage.com.au":"mira"}
# VITE_SHOP_DOMAIN_MAP={"mirathaimassage.com.au":"mira"}

# Slack-compatible webhook when an unmapped custom domain is hit at runtime:
# SHOP_DOMAIN_ALERT_WEBHOOK=https://hooks.slack.com/services/...

# Required on Vercel for build-time domain guard (scripts/verify-shop-domains-production.mjs):
# VERCEL_TOKEN=...

# GitHub Actions secrets (Settings → Secrets → Actions) for pre-deploy gate:
# VERCEL_TOKEN, SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY
# Optional: SHOP_DOMAIN_MAP (if production env overrides shops.config.json)

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
