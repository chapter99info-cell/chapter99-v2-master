# Chapter99 multi-tenant platform (chapter99-v2-master)
# Default shop when no ?shop= slug / custom domain: Mira (shop-001)
VITE_SHOP_ID=shop-001

# Phase 1 public booking RPCs — set true only after running supabase/46-public-booking-rpcs.sql
# VITE_BOOKING_RPC_V1=true

# Shop custom domains — primary map is shops.config.json (committed).
# These env vars only OVERRIDE entries in that file (optional):
# SHOP_DOMAIN_MAP={"jasminethaispa.com.au":"jasmine-thai-spa02","koalawellness-demo.vercel.app":"koala-wellness-spa"}
# VITE_SHOP_DOMAIN_MAP={"jasminethaispa.com.au":"jasmine-thai-spa02"}
